          Payfinia Admin
        </button>
      </div>

      {mode === 'payfinia' ? (
        <PayfiniaAdminConsole />
      ) : (
        <div className="min-h-screen bg-gray-50 p-6">
          <div className="max-w-6xl mx-auto">
            <div className="mb-6">
              <h1 className="text-2xl font-bold text-gray-800">FI Administration</h1>
              <p className="text-gray-500">Manage users, roles, and organization settings</p>
            </div>
            <FIAdminPanel currentUser={currentUser} fiConfig={{}} />
          </div>
        </div>
      )}
    </div>
  );
}
